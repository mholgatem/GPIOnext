#!/bin/bash
# GPIOnext Remove — Recalbox
#
# Called by: ./manage remove [--purge]
# Receives env vars: GPIONEXT_INSTALL_PATH, GPIONEXT_PURGE, MANAGE_DIR

set -euo pipefail

. "${MANAGE_DIR}/setup/lib.sh"

PID_FILE="/run/gpionext.pid"
CUSTOM_SH="/recalbox/share/system/custom.sh"
USERSCRIPTS_DIR="/recalbox/share/userscripts/manual"
UDEV_RULE="/etc/udev/rules.d/10-gpionext.rules"

# ---------------------------------------------------------------------------
# Platform validation
# ---------------------------------------------------------------------------

if [ ! -d /recalbox/share ]; then
    echo -e "${RED}Error: This script is for Recalbox only.${NONE}" >&2
    exit 1
fi

echo
echo -e "${RED}Removing GPIOnext (Recalbox)...${NONE}"
[ "$GPIONEXT_PURGE" = "true" ] && echo -e "${FUSCHIA}--purge: config will also be removed.${NONE}"
echo

# ---------------------------------------------------------------------------
# Stop daemon
# ---------------------------------------------------------------------------

if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    echo "Stopping GPIOnext daemon..."
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
    rm -f "$PID_FILE"
else
    pkill -f '/tmp/gpionext' 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Remove startup hook from custom.sh
# ---------------------------------------------------------------------------

if [ -f "$CUSTOM_SH" ] && grep -q '# GPIOnext begin' "$CUSTOM_SH"; then
    echo "Removing startup hook from ${CUSTOM_SH}..."
    sed -i '/# GPIOnext begin/,/# GPIOnext end/d' "$CUSTOM_SH"
fi

# ---------------------------------------------------------------------------
# Remove User Scripts
# ---------------------------------------------------------------------------

if [ -d "$USERSCRIPTS_DIR" ]; then
    for f in "${USERSCRIPTS_DIR}/GPIOnext"*.sh; do
        [ -f "$f" ] && rm -f "$f" && echo "Removed ${f}"
    done
fi

# ---------------------------------------------------------------------------
# Remove udev rule (may not exist on Recalbox)
# ---------------------------------------------------------------------------

[ -f "$UDEV_RULE" ] && rm -f "$UDEV_RULE"
udevadm control --reload-rules 2>/dev/null || true

# ---------------------------------------------------------------------------
# Remove install directory
# ---------------------------------------------------------------------------

if [ -d "$GPIONEXT_INSTALL_PATH" ]; then
    if [ "$GPIONEXT_PURGE" = "true" ]; then
        echo "Removing ${GPIONEXT_INSTALL_PATH}..."
        rm -rf "$GPIONEXT_INSTALL_PATH"
    else
        echo "Removing binaries (keeping config/)..."
        find "$GPIONEXT_INSTALL_PATH" -mindepth 1 -maxdepth 1 ! -name "config" -exec rm -rf {} +
    fi
fi

echo
if [ "$GPIONEXT_PURGE" = "true" ]; then
    echo -e "${GREEN}GPIOnext removed (including config).${NONE}"
else
    echo -e "${GREEN}GPIOnext removed. Config preserved at ${GPIONEXT_INSTALL_PATH}/config/${NONE}"
fi
echo
