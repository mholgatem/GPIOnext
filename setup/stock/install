#!/bin/bash
# GPIOnext Install — Stock (Debian / Raspberry Pi OS)
#
# Called by: ./manage install
# Receives env vars: GPIONEXT_VERSION, GPIONEXT_ARCH, GPIONEXT_INSTALL_PATH, MANAGE_DIR

set -euo pipefail

. "${MANAGE_DIR}/setup/lib.sh"

SERVICE_NAME="gpionext"
SERVICE_FILE="/lib/systemd/system/${SERVICE_NAME}.service"
UDEV_RULE="/etc/udev/rules.d/10-gpionext.rules"
CLI_BIN="/usr/bin/gpionext"

# ---------------------------------------------------------------------------
# Platform validation
# ---------------------------------------------------------------------------

if [ ! -f /etc/debian_version ]; then
    echo -e "${RED}Error: This script is for Debian / Raspberry Pi OS only.${NONE}" >&2
    exit 1
fi

echo -e "${CYAN}${BOLD}GPIOnext Installer — Stock (Debian)${NONE}"
echo

# ---------------------------------------------------------------------------
# Debian version detection
# ---------------------------------------------------------------------------

DEBIAN_VERSION=$(cut -d '.' -f 1 /etc/debian_version 2>/dev/null || echo "11")
IS_BOOKWORM=false
if [ "$DEBIAN_VERSION" -ge 12 ] 2>/dev/null; then
    IS_BOOKWORM=true
fi
echo -e "Debian version: ${FUSCHIA}${DEBIAN_VERSION}${NONE} (Bookworm+: ${IS_BOOKWORM})"
echo

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------

echo -e "${CYAN}${UNDERLINE}Updating package lists...${NONE}"
apt-get update -q

echo -e "${CYAN}${UNDERLINE}Installing system dependencies...${NONE}"

LIBGPIOD_RT="libgpiod2"
$IS_BOOKWORM && LIBGPIOD_RT="libgpiod3"

apt-get -y install curl git i2c-tools "${LIBGPIOD_RT}"

# ---------------------------------------------------------------------------
# Directory structure
# ---------------------------------------------------------------------------

echo -e "${CYAN}${UNDERLINE}Setting up ${GPIONEXT_INSTALL_PATH}...${NONE}"
mkdir -p "${GPIONEXT_INSTALL_PATH}/config" "${GPIONEXT_INSTALL_PATH}/bin"
echo "stock" > "${GPIONEXT_INSTALL_PATH}/PLATFORM"

# ---------------------------------------------------------------------------
# Download binaries
# ---------------------------------------------------------------------------

echo -e "${CYAN}${UNDERLINE}Downloading GPIOnext binaries (${GPIONEXT_VERSION} / ${GPIONEXT_ARCH})...${NONE}"
if ! download_tarball "$GPIONEXT_VERSION" "$GPIONEXT_ARCH" "$GPIONEXT_INSTALL_PATH"; then
    echo -e "${RED}Binary download failed. Place binaries manually at:${NONE}"
    echo "  ${GPIONEXT_INSTALL_PATH}/bin/gpionext"
    echo "  ${GPIONEXT_INSTALL_PATH}/bin/gpionext-config"
fi

# ---------------------------------------------------------------------------
# udev rule (SDL2 / emulator compatibility)
# ---------------------------------------------------------------------------

echo -e "${CYAN}${UNDERLINE}Installing udev rule...${NONE}"
echo 'KERNEL=="event*", ATTRS{idVendor}=="9999", ATTRS{idProduct}=="8888", MODE:="0644"' \
    > "$UDEV_RULE"
udevadm control --reload-rules
udevadm trigger

# ---------------------------------------------------------------------------
# I2C activation
# ---------------------------------------------------------------------------

if [ -f /usr/bin/raspi-config ]; then
    echo -e "${CYAN}${UNDERLINE}Activating I2C interface...${NONE}"
    raspi-config nonint do_i2c 0 || true
fi

# ---------------------------------------------------------------------------
# Kernel modules
# ---------------------------------------------------------------------------

grep -qxF 'uinput'  /etc/modules || echo 'uinput'   >> /etc/modules
grep -qxF 'evdev'   /etc/modules || echo 'evdev'    >> /etc/modules
grep -qxF 'i2c-dev' /etc/modules || echo 'i2c-dev'  >> /etc/modules
modprobe uinput  2>/dev/null || true
modprobe evdev   2>/dev/null || true
modprobe i2c-dev 2>/dev/null || true

# ---------------------------------------------------------------------------
# systemd service
# ---------------------------------------------------------------------------

echo -e "${CYAN}${UNDERLINE}Installing systemd service...${NONE}"
if [ -f "${MANAGE_DIR}/gpionext.service" ]; then
    cp "${MANAGE_DIR}/gpionext.service" "$SERVICE_FILE"
    systemctl daemon-reload
    systemctl enable "$SERVICE_NAME"
else
    echo -e "${FUSCHIA}Warning: gpionext.service not found in repo. Service not installed.${NONE}"
fi

# ---------------------------------------------------------------------------
# CLI wrapper
# ---------------------------------------------------------------------------

echo -e "${CYAN}${UNDERLINE}Installing CLI wrapper...${NONE}"
if [ -f "${MANAGE_DIR}/usr-bin-gpionext" ]; then
    install -m 755 "${MANAGE_DIR}/usr-bin-gpionext" "$CLI_BIN"
fi

# ---------------------------------------------------------------------------
# retrogame conflict check
# ---------------------------------------------------------------------------

for rg_file in /etc/rc.local /home/pi/.profile; do
    if [ -f "$rg_file" ] && grep -q "retrogame" "$rg_file"; then
        echo
        echo -e "${FUSCHIA}retrogame detected in ${rg_file}.${NONE}"
        read -rp "Disable retrogame on startup? [y/N] " USER_INPUT
        if [[ "$USER_INPUT" =~ ^[Yy] ]]; then
            sed -i '/retrogame/s/^#*/: #/' "$rg_file"
            echo -e "${CYAN}retrogame disabled.${NONE}"
        fi
        break
    fi
done

# ---------------------------------------------------------------------------
# Start service
# ---------------------------------------------------------------------------

if systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null; then
    systemctl start "$SERVICE_NAME" 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------

clear
echo
echo -e "${GREEN}${BOLD}GPIOnext installation complete!${NONE}"
echo
echo -e "Install path: ${CYAN}${GPIONEXT_INSTALL_PATH}${NONE}"
echo -e "Version:      ${CYAN}${GPIONEXT_VERSION}${NONE}"
echo

read -rp $'\e[35m\e[4mRun the config tool now?\e[0m [Y/N] ' USER_INPUT
if [[ "$USER_INPUT" =~ ^[Yy] ]]; then
    "${GPIONEXT_INSTALL_PATH}/bin/gpionext-config" \
        --config "${GPIONEXT_INSTALL_PATH}/config/gpionext.json"
fi
echo
