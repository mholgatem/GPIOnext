#!/bin/bash
# GPIOnext Remove — Stock (Debian / Raspberry Pi OS)
#
# Called by: ./manage remove [--purge]
# Receives env vars: GPIONEXT_INSTALL_PATH, GPIONEXT_PURGE, MANAGE_DIR

set -euo pipefail

. "${MANAGE_DIR}/setup/lib.sh"

SERVICE_NAME="gpionext"
SERVICE_FILE="/lib/systemd/system/${SERVICE_NAME}.service"
UDEV_RULE="/etc/udev/rules.d/10-gpionext.rules"
CLI_BIN="/usr/bin/gpionext"

# ---------------------------------------------------------------------------
# Platform validation
# ---------------------------------------------------------------------------

if [ ! -f /etc/debian_version ]; then
    echo -e "${RED}Error: This script is for Debian / Raspberry Pi OS only.${NONE}" >&2
    exit 1
fi

echo
echo -e "${RED}Removing GPIOnext (Stock)...${NONE}"
[ "$GPIONEXT_PURGE" = "true" ] && echo -e "${FUSCHIA}--purge: config will also be removed.${NONE}"
echo

# ---------------------------------------------------------------------------
# Stop and disable systemd service
# ---------------------------------------------------------------------------

if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
    echo "Stopping ${SERVICE_NAME} service..."
    systemctl stop "$SERVICE_NAME"
fi

if systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null; then
    echo "Disabling ${SERVICE_NAME} service..."
    systemctl disable "$SERVICE_NAME"
fi

[ -f "$SERVICE_FILE" ] && rm -f "$SERVICE_FILE"
systemctl daemon-reload 2>/dev/null || true

# ---------------------------------------------------------------------------
# Remove udev rule
# ---------------------------------------------------------------------------

[ -f "$UDEV_RULE" ] && rm -f "$UDEV_RULE"
udevadm control --reload-rules 2>/dev/null || true

# ---------------------------------------------------------------------------
# Remove CLI wrapper
# ---------------------------------------------------------------------------

[ -f "$CLI_BIN" ] && rm -f "$CLI_BIN"

# ---------------------------------------------------------------------------
# Remove install directory
# ---------------------------------------------------------------------------

if [ -d "$GPIONEXT_INSTALL_PATH" ]; then
    if [ "$GPIONEXT_PURGE" = "true" ]; then
        echo "Removing ${GPIONEXT_INSTALL_PATH}..."
        rm -rf "$GPIONEXT_INSTALL_PATH"
    else
        echo "Removing binaries (keeping config/)..."
        find "$GPIONEXT_INSTALL_PATH" -mindepth 1 -maxdepth 1 ! -name "config" -exec rm -rf {} +
    fi
fi

# ---------------------------------------------------------------------------
# Offer to re-enable retrogame
# ---------------------------------------------------------------------------

for rg_file in /etc/rc.local /home/pi/.profile; do
    if [ -f "$rg_file" ] && grep -q "retrogame" "$rg_file"; then
        echo
        echo -e "${CYAN}retrogame detected in ${rg_file}.${NONE}"
        read -rp "Re-enable retrogame on startup? [y/N] " USER_INPUT
        if [[ "$USER_INPUT" =~ ^[Yy] ]]; then
            sed -i '/retrogame/s/^: #//' "$rg_file"
            echo -e "${CYAN}retrogame re-enabled.${NONE}"
        fi
        break
    fi
done

echo
if [ "$GPIONEXT_PURGE" = "true" ]; then
    echo -e "${GREEN}GPIOnext removed (including config).${NONE}"
else
    echo -e "${GREEN}GPIOnext removed. Config preserved at ${GPIONEXT_INSTALL_PATH}/config/${NONE}"
fi
echo
