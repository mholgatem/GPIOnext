#!/bin/bash
# GPIOnext Remove — Batocera
#
# Called by: ./manage remove [--purge]
# Receives env vars: GPIONEXT_INSTALL_PATH, GPIONEXT_PURGE, MANAGE_DIR

set -euo pipefail

. "${MANAGE_DIR}/setup/lib.sh"

SERVICE_SCRIPT="/userdata/system/services/gpionext"
ES_CUSTOM_CFG="/userdata/system/configs/emulationstation/es_systems_custom.cfg"
ROMS_DIR="/userdata/roms/gpionext"
UDEV_RULE="/etc/udev/rules.d/10-gpionext.rules"

# ---------------------------------------------------------------------------
# Platform validation
# ---------------------------------------------------------------------------

if [ ! -f /etc/batocera-release ]; then
    echo -e "${RED}Error: This script is for Batocera only.${NONE}" >&2
    exit 1
fi

echo
echo -e "${RED}Removing GPIOnext (Batocera)...${NONE}"
[ "$GPIONEXT_PURGE" = "true" ] && echo -e "${FUSCHIA}--purge: config will also be removed.${NONE}"
echo

# ---------------------------------------------------------------------------
# Stop daemon
# ---------------------------------------------------------------------------

if [ -f "$SERVICE_SCRIPT" ]; then
    echo "Stopping GPIOnext daemon..."
    bash "$SERVICE_SCRIPT" stop 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Remove service script
# ---------------------------------------------------------------------------

[ -f "$SERVICE_SCRIPT" ] && rm -f "$SERVICE_SCRIPT" && echo "Removed service: ${SERVICE_SCRIPT}"

# ---------------------------------------------------------------------------
# Remove ES custom system entry
# ---------------------------------------------------------------------------

if [ -f "$ES_CUSTOM_CFG" ] && grep -q '<!-- GPIOnext begin -->' "$ES_CUSTOM_CFG"; then
    echo "Removing GPIOnext entry from ${ES_CUSTOM_CFG}..."
    sed -i '/<!-- GPIOnext begin -->/,/<!-- GPIOnext end -->/d' "$ES_CUSTOM_CFG"
fi

# ---------------------------------------------------------------------------
# Remove ROM shortcuts
# ---------------------------------------------------------------------------

[ -d "$ROMS_DIR" ] && rm -rf "$ROMS_DIR" && echo "Removed ROM shortcuts: ${ROMS_DIR}"

# ---------------------------------------------------------------------------
# Remove udev rule
# ---------------------------------------------------------------------------

[ -f "$UDEV_RULE" ] && rm -f "$UDEV_RULE"
udevadm control --reload-rules 2>/dev/null || true

# ---------------------------------------------------------------------------
# Remove install directory
# ---------------------------------------------------------------------------

if [ -d "$GPIONEXT_INSTALL_PATH" ]; then
    if [ "$GPIONEXT_PURGE" = "true" ]; then
        echo "Removing ${GPIONEXT_INSTALL_PATH}..."
        rm -rf "$GPIONEXT_INSTALL_PATH"
    else
        echo "Removing binaries (keeping config/)..."
        find "$GPIONEXT_INSTALL_PATH" -mindepth 1 -maxdepth 1 ! -name "config" -exec rm -rf {} +
    fi
fi

echo
if [ "$GPIONEXT_PURGE" = "true" ]; then
    echo -e "${GREEN}GPIOnext removed (including config). Restart EmulationStation to update the system list.${NONE}"
else
    echo -e "${GREEN}GPIOnext removed. Config preserved at ${GPIONEXT_INSTALL_PATH}/config/${NONE}"
    echo -e "Restart EmulationStation to update the system list."
fi
echo
